{
  "name": "scan-bo",
  "version": "1.0.0",
  "description": "Aplicacion de escaneo QR para facturas",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:backend": "node scripts/build-python.js backend",
    "build:siat": "node scripts/build-python.js siat",
    "dist:linux": "pnpm run build:backend && pnpm run build:siat && electron-builder --linux AppImage",
    "dist:win": "pnpm run build:backend && pnpm run build:siat && electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "bo.scanbo.app",
    "productName": "Scanner Facturas",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "siat.js",
      "db.js",
      "assets/*.png",
      "!python/**"
    ],
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office",
      "extraResources": [
        { "from": "python/dist/backend", "to": "backend/backend" },
        { "from": "python/dist/siat_automation", "to": "backend/siat_automation" }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "python/dist/backend.exe", "to": "backend/backend.exe" },
        { "from": "python/dist/siat_automation.exe", "to": "backend/siat_automation.exe" }
      ]
    }
  }
}
