{
  "name": "scan-bo",
  "version": "1.0.0",
  "description": "Aplicacion de escaneo QR para facturas",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "PYTHONPATH=\"../venv/lib/python3.14/site-packages\" electron-builder install-app-deps",
    "build:backend": "../venv/bin/pyinstaller --onefile --name backend --clean --distpath python/dist --workpath python/build --specpath python python/backend.py",
    "build:siat": "../venv/bin/pyinstaller --onefile --name siat_automation --clean --distpath python/dist --workpath python/build --specpath python --collect-all selenium --collect-all webdriver_manager python/siat_automation.py",
    "dist:linux": "pnpm run build:backend && pnpm run build:siat && electron-builder --linux AppImage"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "bo.scanbo.app",
    "productName": "Scanner Facturas",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "siat.js",
      "db.js",
      "assets/*.png",
      "!python/**"
    ],
    "extraResources": [
      {
        "from": "python/dist/backend",
        "to": "backend/backend"
      },
      {
        "from": "python/dist/siat_automation",
        "to": "backend/siat_automation"
      }
    ],
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
